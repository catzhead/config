#!/bin/sh
# Hash dependency so this re-runs when the plugin list changes:
# tmux.conf hash: {{ include "dot_config/tmux/tmux.conf.tmpl" | sha256sum }}
set -eu

TPM_DIR="${HOME}/.config/tmux/plugins/tpm"

if [ ! -d "$TPM_DIR" ]; then
    git clone --depth=1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
fi

"$TPM_DIR/bin/install_plugins"
